# Backend environment variables
# Copy this file to backend/.env and fill in values for local development.
# Never commit backend/.env (covered by root .gitignore).

# HTTP listen port (defaults to 3001 if unset)
PORT=3001

# Node environment
NODE_ENV=development

# eBay marketplace account deletion notifications (compliance endpoint).
# Both values must be shared with eBay when subscribing to account-deletion
# notifications in the developer console — they are required to enable the
# eBay production keyset. The verification token is a 32–80 character
# string of [A-Za-z0-9_-] that you choose; the endpoint URL is the public
# HTTPS URL where the GET/POST handlers are reachable.
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=
EBAY_ACCOUNT_DELETION_ENDPOINT_URL=https://ebay.rycsprojects.com/api/ebay/account-deletion
