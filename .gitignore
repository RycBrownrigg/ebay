# =============================================================================
# .gitignore — Rust · Polkadot SDK / FRAME Pallets · ink! 6 Smart Contracts
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
**/target/
Cargo.lock          # remove this line if you are publishing a binary crate
**/*.rs.bk
*.pdb

# Cargo cache artefacts
.cargo/registry/
.cargo/git/
.cargo/.package-cache

# Cargo home (when overridden locally)
CARGO_HOME/

# Generated by `cargo vendor`
vendor/

# Benchmark / profiling output produced by cargo-criterion, cargo-bench, etc.
criterion/
flamegraph.svg
perf.data
perf.data.old

# -----------------------------------------------------------------------------
# Polkadot SDK / Substrate / FRAME
# -----------------------------------------------------------------------------

# Compiled WASM runtimes (checked-in blob is intentional in most repos;
# remove the negation below if you DO want to track the blob)
/runtime/target/
**/*.wasm
# !runtime/src/weights/*.wasm   # uncomment to keep pre-built weight blobs

# Weight files auto-generated by the benchmarking CLI
# (keep hand-written placeholder files; ignore machine-generated output)
**/weights/generated_*.rs
**/weights/pallet_*_weights.rs

# Substrate node key-files created by `--dev` / `--tmp` runs
*.key
node-key

# Chain spec JSON files generated at runtime (keep authored ones)
*-generated.json
chainspec-*.json

# Keystore directories populated by a running node
keystore/
chains/*/keystore/

# Local database directories (RocksDB / ParityDB)
chains/
db/
.local/

# Zombienet / chopsticks local state
.zombienet/
.chopsticks/

# Omni-node / polkadot-parachain ephemeral data
polkadot-data/
parachain-data/

# Relay-chain / collator session artefacts
relay-chain/
collator-data/

# Docker-compose volumes for local devnets
.devnet/
docker-volumes/

# cargo-contract / ink! artefacts
# ink! 6 places build output under <crate>/target by default,
# but the CLI also writes alongside the manifest:
**/*.contract
**/*.wasm           # already covered above — kept explicit for clarity
**/*.json           # generated metadata; remove if you track ABI files
!**/artifacts/**/*.json   # keep hand-curated artifact snapshots

# ink! end-to-end test cache
e2e-tests/.cache/
.drink/

# cargo-dylint / clippy-driven lints local state
.dylint_libs/

# SCALE codec fuzzing corpora
fuzz/corpus/
fuzz/artifacts/

# cargo-fuzz
fuzz/target/

# Tracing / telemetry output
jaeger-data/
tempo-data/

# -----------------------------------------------------------------------------
# Development tooling
# -----------------------------------------------------------------------------

# rust-analyzer
.rust-analyzer/

# IntelliJ / CLion / RustRover
.idea/
*.iml
*.iws
out/

# VS Code
.vscode/
!.vscode/extensions.json   # keep recommended extensions list
!.vscode/settings.json.example

# Vim / Neovim
*.swp
*.swo
.netrwhist
Session.vim
tags

# Emacs
*~
\#*\#
.\#*
*.elc
auto-save-list

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example       # keep the documented template
*.secret
secrets/
mnemonic.txt
seed.txt
*.seed
private_key*
*.priv

# -----------------------------------------------------------------------------
# CI / CD ephemeral artefacts
# -----------------------------------------------------------------------------
.github/workflows/__pycache__/
junit-*.xml
coverage/
lcov.info
*.profraw
*.profdata
tarpaulin-report.*

# -----------------------------------------------------------------------------
# Documentation builds
# -----------------------------------------------------------------------------
/doc/
/docs/book/book/
mdbook-output/
Implementation Decisions & Design Rationale.md

# -----------------------------------------------------------------------------
# Claude / Anthropic
# -----------------------------------------------------------------------------

# Claude Code project memory (local to each developer's machine)
CLAUDE.md
.claude/
.claude_cache/

# Claude Code session artefacts & conversation exports
.claude_session
claude_output/
claude-artifacts/

# MCP (Model Context Protocol) server config — may contain local paths / keys
.mcp.json
mcp-config.json

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
*.patch
nohup.out
go-ethereum/
lodestar/
snowbridge/
