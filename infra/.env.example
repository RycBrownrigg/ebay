# Compose-level environment variables for the ebay stack.
# Copy to infra/.env on the VPS (chmod 600) and fill in.
# Never commit infra/.env (covered by root .gitignore).

# Postgres ----------------------------------------------------------------
# Strong random string. Suggested generator (note: must strip newlines and
# spaces — openssl wraps base64 output at 64 chars by default):
#   openssl rand -base64 48 | tr -d '\n /+=' | cut -c1-32
POSTGRES_PASSWORD=

# eBay marketplace account-deletion compliance endpoint -------------------
# These are read by the api container (env_file: .env) and surfaced to
# @ebay/backend at runtime. Both must be shared with eBay when subscribing
# to account-deletion notifications in the developer console.
#
# Verification token: 32–80 chars of [A-Za-z0-9_-] that you choose. Must
# match exactly what you enter in eBay's console. Suggested generator
# (note: must strip newlines and spaces — openssl wraps base64 output at
# 64 chars by default, and an embedded space will fail eBay's validation):
#   openssl rand -base64 80 | tr -d '\n /+=' | cut -c1-64
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=

# Endpoint URL: the public HTTPS URL where the GET/POST handlers live.
# Used in the SHA256 hash that eBay verifies during subscription setup.
EBAY_ACCOUNT_DELETION_ENDPOINT_URL=https://ebay.rycsprojects.com/api/ebay/account-deletion
